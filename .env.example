# ── Server ──
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/metaverse?retryWrites=true&w=majority
JWT_SECRET=change-me-generate-64-char-random-string-here
JWT_REFRESH_SECRET=change-me-generate-another-64-char-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost:3000
STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:your-domain.com:3478
# TURN_USERNAME=turnuser
# TURN_PASSWORD=securepassword123

# ── Client ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
